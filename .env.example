DISCORD_TOKEN=your_bot_token_here
# If Render login hits Discord 429, the bot waits and retries (do not run bot locally with same token)
# DISCORD_LOGIN_MAX_ATTEMPTS=6
# DISCORD_LOGIN_DELAY_SECONDS=0
# Join-to-create hub voice channel IDs (update if you recreate the hub channels)
# CREATE_CHANNEL_ID=1517870390968582155
# SUPPORT_CHANNEL_ID=1518020513174130769
# VERIFICATION_1_ID=1517597478378143937
# VERIFICATION_2_ID=1517666468593143940
# Punishment cards are posted to channel ID 1522676265381793876 (hardcoded in bot.py)
# Optional: override bot-chat channel ID (default: 1518023858765168771)
# BOT_CHAT_CHANNEL_ID=1518023858765168771
# Optional: message sent in bot-chat (refreshed periodically)
# BOT_CHAT_MESSAGE=welcome to Bot-Chat
# Set server default notifications to @mentions only on startup (default: true)
# SET_DEFAULT_NOTIFICATIONS_ONLY_MENTIONS=true
# BOT_CHAT_KEEPALIVE_MINUTES=30
# EMPTY_ROOM_CLEANUP_MINUTES=10
# PUNISHMENT_POST_CAP=5
# WELCOME_POST_CAP=5
# SYNCROLES_MEMBER_DELAY=0.35
# GUILD_INIT_STEP_DELAY=0.4
