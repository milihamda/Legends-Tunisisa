DISCORD_TOKEN=your_bot_token_here
# Optional: override bot-chat channel ID (default: 1518023858765168771)
# BOT_CHAT_CHANNEL_ID=1518023858765168771
# Optional: message sent every minute in bot-chat (old message is deleted first)
# BOT_CHAT_MESSAGE=welcome to Bot-Chat
# Set server default notifications to @mentions only on startup (default: true)
# SET_DEFAULT_NOTIFICATIONS_ONLY_MENTIONS=true
